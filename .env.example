# =============================================================================
# Plasma Store — variables de entorno (ejemplo)
# =============================================================================
# Paso 1: Copia este archivo a la raíz del proyecto (_plasma_upload):
#         copy .env.example .env.local   (Windows)
#         cp .env.example .env.local     (macOS / Linux)
# Paso 2: Rellena MONGODB_URI y APP_SESSION_SECRET con valores reales.
# Paso 3: En Mongo Atlas → Network Access → añade 0.0.0.0/0 (o IPs de Vercel).
# Paso 4: Local → npm run check-env  y  npm run dev  (http://localhost:3000)
# Paso 5: Vercel → Settings → Environment Variables (mismas claves que aquí).
# =============================================================================

# Obligatorias (app + API)
MONGODB_URI=mongodb+srv://USUARIO:CONTRASE%C3%91A@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=plasmastore
APP_SESSION_SECRET=cambia-por-un-secreto-largo-aleatorio-minimo-32-caracteres

# Solo si ejecutas Express solo: node server/src/index.mjs (puerto por defecto 3847)
PORT=3847

# Opcional: front y API en dominios distintos (CORS). En un solo dominio Next suele no hacer falta.
# FRONTEND_ORIGIN=https://tu-dominio.vercel.app

# --- npm run create-admin (solo si aún no hay ningún admin en la BD) ---
# --- npm run set-admin-password (si el usuario ya existe pero pass_hash está mal / texto plano) ---
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=contraseña-segura-min-6

# --- POST /api/store/bootstrap-admin (BD sin usuarios; una sola vez) ---
# BOOTSTRAP_TOKEN=token-secreto-de-un-solo-uso

# Opcional: subpath en producción (React Router). Normalmente vacío.
# NEXT_PUBLIC_BASE_PATH=

# Si en Windows ves: querySrv ECONNREFUSED _mongodb._tcp...
# → el servidor ya usa 8.8.8.8/8.8.4.4 solo dentro de Node (sin admin). Para desactivarlo: MONGODB_NODE_PUBLIC_DNS=0
# → DNS alternativos solo para Node: MONGODB_DNS_SERVERS=1.1.1.1,1.0.0.1
# → en Atlas: cluster no "Paused"; Network Access con 0.0.0.0/0 o tu IP.
# → MONGODB_FORCE_IPV4=0 / MONGODB_IPV4_FIRST=0 si molestan en otro SO.

# Reintentos / timeouts de Mongo (para conexiones SRV inestables)
MONGODB_CONNECT_RETRIES=6
MONGODB_SERVER_SELECTION_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=20000

# Webpay (si lo usas)
# WEBPAY_ENV=integration
# WEBPAY_COMMERCE_CODE=
# WEBPAY_API_KEY=
# PUBLIC_BASE_URL=https://tu-dominio.vercel.app
