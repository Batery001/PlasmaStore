# En Vercel: Settings → Environment Variables (Production / Preview): mismas claves que arriba.
# Opcional si front y API fueran dominios distintos:
# FRONTEND_ORIGIN=https://tu-proyecto.vercel.app

# Crear el primer admin en Mongo (script local): npm run create-admin (en la raíz del repo)
# ADMIN_EMAIL=admin@tudominio.cl
# ADMIN_PASSWORD=contraseña-segura-min-6

# O una sola vez por HTTP: POST /api/store/bootstrap-admin + header x-bootstrap-token
# BOOTSTRAP_TOKEN=token-secreto-de-un-solo-uso
