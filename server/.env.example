PORT=3847
MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=plasmastore
APP_SESSION_SECRET=cambia-por-un-secreto-largo-aleatorio-minimo-32-caracteres

# En Vercel: Settings → Environment Variables (mismas claves). Valores reales solo en server/.env (local, no subir).

# Opcional CORS si front y API van en dominios distintos:
# FRONTEND_ORIGIN=https://tu-proyecto.vercel.app

# Script local para crear el primer admin: npm run create-admin (desde la raíz del repo)
# ADMIN_EMAIL=admin@tudominio.cl
# ADMIN_PASSWORD=contraseña-segura-min-6

# O HTTP una vez (BD sin usuarios): POST /api/store/bootstrap-admin + header x-bootstrap-token
# BOOTSTRAP_TOKEN=token-secreto-de-un-solo-uso
